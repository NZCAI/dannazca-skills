{
  "mcpServers": {
    "edgartools": {
      "type": "stdio",
      "command": "uvx",
      "args": [
        "--from",
        "edgartools[ai]",
        "edgartools-mcp"
      ],
      "env": {
        "EDGAR_IDENTITY": "Your Name your.email@example.com"
      },
      "disabled": false
    },
    "edgar517": {
      "type": "stdio",
      "command": "uvx",
      "args": [
        "--from",
        "edgartools[ai]==5.17.1",
        "edgartools-mcp"
      ],
      "env": {
        "EDGAR_IDENTITY": "Your Name your.email@example.com"
      },
      "disabled": true
    },
    "edgartools-http": {
      "type": "http",
      "url": "http://127.0.0.1:8765/mcp",
      "disabled": true
    }
  }
}
